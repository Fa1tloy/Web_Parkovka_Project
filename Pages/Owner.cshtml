@page
@model Web_Parkovka_Project.Pages.OwnerModel
@{
}

<h2>@ViewData["Title"]</h2>

<form method="post">
    
    <input type="hidden" asp-for="Owner.Id" />
    <div class="form-group">
        <label asp-for="Owner.Name">ФИО</label>
        <input asp-for="Owner.Name" type="text" class="form-control" />
        <span asp-validation-for="Owner.Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Owner.Email">Электронная почта</label>
        <input asp-for="Owner.Email" type="text" class="form-control" />
        <span asp-validation-for="Owner.Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Owner.Phone">Номер телефона</label>
        <input asp-for="Owner.Phone" type="number" class="form-control" />
        <span asp-validation-for="Owner.Phone" class="text-danger"></span>
    </div>
<</form>>