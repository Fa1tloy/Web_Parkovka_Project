@page
@model Web_Parkovka_Project.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Мой профиль";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <span class="profile-icon" style="font-size: 5rem;">👤</span>
                    </div>
                    <h3>@Model.CurrentUser.FullName</h3>
                    <p class="text-muted">@Model.CurrentUser.Email</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4>Личные данные</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Имя</label>
                                <input asp-for="Input.Name" class="form-control" />
                                <span asp-validation-for="Input.Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Фамилия</label>
                                <input asp-for="Input.Surname" class="form-control" />
                                <span asp-validation-for="Input.Surname" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Отчество</label>
                                <input asp-for="Input.Patronymic" class="form-control" />
                                <span asp-validation-for="Input.Patronymic" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Input.Email" class="form-control" disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Телефон</label>
                            <input asp-for="Input.PhoneNumber" class="form-control" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h4>Мои транспортные средства</h4>
                </div>
                <div class="card-body">
                    @if (Model.CurrentUser.Vehicles.Any())
                    {
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Марка</th>
                                    <th>Модель</th>
                                    <th>Номер</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vehicle in Model.CurrentUser.Vehicles)
                                {
                                    <tr>
                                        <td>@vehicle.Make</td>
                                        <td>@vehicle.Model</td>
                                        <td>@vehicle.LicensePlate</td>
                                        <td>
                                            <form method="post" asp-page-handler="DeleteVehicle" asp-route-id="@vehicle.Id">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Нет зарегистрированных транспортных средств</p>
                    }
                    <button class="btn btn-success mt-2" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                        Добавить транспортное средство
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно для добавления ТС -->
<div class="modal fade" id="addVehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Добавить транспортное средство</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addVehicleForm" method="post" asp-page-handler="AddVehicle">
                    <div class="mb-3">
                        <label class="form-label">Марка</label>
                        <input name="Make" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Модель</label>
                        <input name="Model" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Гос. номер</label>
                        <input name="LicensePlate" class="form-control" required
                               pattern="[A-ZА-Я]\d{5}"
                               title="Формат: одна заглавная буква и пять цифр (пример: A12345)" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="submit" form="addVehicleForm" class="btn btn-primary">Добавить</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
}