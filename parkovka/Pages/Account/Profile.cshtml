@page
@model Web_Parkovka_Project.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Мой профиль";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Блок профиля -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-body p-4 text-center">
                    <div class="avatar-wrapper mb-3">
                        <div class="avatar bg-primary bg-opacity-10 p-4 rounded-circle d-inline-flex align-items-center justify-content-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-person text-primary" viewBox="0 0 16 16">
                                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" />
                            </svg>
                        </div>
                    </div>
                    <h3 class="mb-1">@Model.CurrentUser.FullName</h3>
                    <p class="text-muted mb-3">@Model.CurrentUser.Email</p>
                    <div class="d-grid">
                        <button class="btn btn-outline-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                            <i class="bi bi-pencil-square me-2"></i>Редактировать профиль
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Основная информация -->
        <div class="col-lg-8">
            <!-- Личные данные -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-light border-0 py-3">
                    <h4 class="mb-0"><i class="bi bi-person-lines-fill text-primary me-2"></i>Личные данные</h4>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="info-item">
                                <label class="text-muted small mb-1">Имя</label>
                                <p class="mb-0 fw-medium">@Model.CurrentUser.Name</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <label class="text-muted small mb-1">Фамилия</label>
                                <p class="mb-0 fw-medium">@Model.CurrentUser.Surname</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <label class="text-muted small mb-1">Отчество</label>
                                <p class="mb-0 fw-medium">@(Model.CurrentUser.Patronymic ?? "Не указано")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <label class="text-muted small mb-1">Телефон</label>
                                <p class="mb-0 fw-medium">@Model.CurrentUser.PhoneNumber</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Транспортные средства -->
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-light border-0 py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-car-front text-primary me-2"></i>Мои транспортные средства</h4>
                    <button class="btn btn-sm btn-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                        <i class="bi bi-plus-circle me-1"></i>Добавить
                    </button>
                </div>
                <div class="card-body p-4">
                    @if (Model.CurrentUser.Vehicles.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr class="table-light">
                                        <th>Марка</th>
                                        <th>Модель</th>
                                        <th>Гос. номер</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var vehicle in Model.CurrentUser.Vehicles)
                                    {
                                        <tr>
                                            <td>@vehicle.Make</td>
                                            <td>@vehicle.Model</td>
                                            <td>
                                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 font-monospace">@vehicle.LicensePlate</span>
                                            </td>
                                            <td class="text-end">
                                                <form method="post" asp-page-handler="DeleteVehicle" asp-route-id="@vehicle.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                                        <i class="bi bi-trash me-1"></i>Удалить
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#adb5bd" class="bi bi-car" viewBox="0 0 16 16">
                                <path d="M2.52 3.515A2.5 2.5 0 0 1 4.82 2h6.362c1 0 1.904.596 2.298 1.515l.792 1.848c.075.175.21.319.38.404.5.25.855.715.965 1.262l.335 1.679c.033.161.049.325.049.49v.413c0 .814-.39 1.543-1 1.997V13.5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-1.338c-1.292.048-2.745.088-4 .088s-2.708-.04-4-.088V13.5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-1.892c-.61-.454-1-1.183-1-1.997v-.413a2.5 2.5 0 0 1 .049-.49l.335-1.68c.11-.546.465-1.012.964-1.261a.807.807 0 0 0 .381-.404l.792-1.848ZM3 10a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm10 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2ZM6 8a1 1 0 0 0 0 2h4a1 1 0 1 0 0-2H6ZM2.906 5.189a.51.51 0 0 0 .497.731c.91-.073 3.35-.17 4.597-.17 1.247 0 3.688.097 4.597.17a.51.51 0 0 0 .497-.731l-.956-1.913A.5.5 0 0 0 11.691 3H4.309a.5.5 0 0 0-.447.276L2.906 5.19Z" />
                            </svg>
                            <h5 class="mt-3 text-muted">Нет транспортных средств</h5>
                            <p class="text-muted mb-4">Добавьте свое первое транспортное средство</p>
                            <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                                <i class="bi bi-plus-circle me-1"></i>Добавить ТС
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно добавления ТС -->
<div class="modal fade" id="addVehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header bg-primary text-white border-0 rounded-top-4">
                <h5 class="modal-title"><i class="bi bi-car-front me-2"></i>Добавить ТС</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="addVehicleForm" method="post" asp-page-handler="AddVehicle">
                    <div class="mb-3">
                        <label class="form-label">Марка</label>
                        <input name="Make" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Модель</label>
                        <input name="Model" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Гос. номер</label>
                        <input name="LicensePlate" class="form-control rounded-3" required
                               pattern="[A-ZА-Я]\d{5}"
                               title="Формат: одна заглавная буква и пять цифр (пример: A12345)" />
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 rounded-bottom-4">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Отмена</button>
                <button type="submit" form="addVehicleForm" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-check-circle me-1"></i>Добавить
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
        }

    .avatar {
        width: 120px;
        height: 120px;
    }

    .info-item {
        background-color: #f8f9fa;
        border-radius: 0.5rem;
        padding: 1rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
    }

    .badge {
        font-family: monospace;
        letter-spacing: 0.5px;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Инициализация модальных окон
        var addVehicleModal = new bootstrap.Modal(document.getElementById('addVehicleModal'));
        var editProfileModal = new bootstrap.Modal(document.getElementById('editProfileModal'));

        // Показать модальное окно редактирования при наличии ошибок
        @if (!ViewData.ModelState.IsValid)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    editProfileModal.show();
                });
            </text>
        }
    </script>
}